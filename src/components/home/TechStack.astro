---
import TechItem from "./TechItem.astro";

const techStack = [
  { name: "TypeScript", icon: "terminal" },
  { name: "Next.js", icon: "data_object" },
  { name: "PostgreSQL", icon: "storage" },
  { name: "AWS / CDK", icon: "cloud" },
  { name: "Docker", icon: "deployed_code" },
  { name: "Rust/WASM", icon: "polyline" },
];
---

<!-- Tech Stack Section -->
<section class="tech-section">
  <div class="container">
    <span class="tag-status">Capabilities_Matrix</span>
    <div class="tech-grid">
      {techStack.map((tech) => <TechItem name={tech.name} icon={tech.icon} />)}
    </div>
  </div>
</section>

<style>
  /* Tech Stack */
  .tech-section {
    background: var(--surface-container);
    padding: 8rem 2rem;

    .tag-status {
      color: var(--secondary);
      display: inline-block;
      font-family: var(--font-headline);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      margin-bottom: 1rem;
      padding: 0;
      text-transform: uppercase;
    }

    .tech-grid {
      @media (width < 768px) {
        grid-template-columns: repeat(2, 1fr);
      }

      @media (width >= 768px) {
        grid-template-columns: repeat(4, 1fr);
      }

      @media (width >= 1024px) {
        grid-template-columns: repeat(6, 1fr);
      }

      display: grid;
      gap: 1rem;
      margin: 0 auto;
      max-width: var(--max-width);
    }
  }
</style>
