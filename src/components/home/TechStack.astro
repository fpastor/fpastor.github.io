---
import TechItem from "./TechItem.astro";

const techStack = [
  { name: "TypeScript", icon: "code_blocks" },
  { name: "Node.js", icon: "memory" },
  { name: "NestJS", icon: "data_array" },
  { name: "MikroORM", icon: "database" },
  { name: "PostgreSQL", icon: "database" },
  { name: "Svelte", icon: "bookmark_heart" },
  { name: "UI/UX", icon: "design_services" },
  { name: "Figma", icon: "design_services" },
  { name: "Docker", icon: "deployed_code" },
  { name: "Git", icon: "difference" },
  { name: "Astro", icon: "planet" },
  { name: "Flutter", icon: "adb" },
];
---

<!-- Tech Stack Section -->
<section class="tech-section">
  <div class="container">
    <span class="tag-status">Tech Stack</span>
    <div class="tech-grid">
      {techStack.map((tech) => <TechItem name={tech.name} icon={tech.icon} />)}
    </div>
  </div>
</section>

<style>
  /* Tech Stack */
  .tech-section {
    background: var(--surface-container);
    padding: 8rem 2rem;

    .tag-status {
      color: var(--secondary);
      display: inline-block;
      font-family: var(--font-headline);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      margin-bottom: 1rem;
      padding: 0;
      text-transform: uppercase;
    }

    .tech-grid {
      @media (width < 768px) {
        grid-template-columns: repeat(2, 1fr);
      }

      @media (width >= 768px) {
        grid-template-columns: repeat(3, 1fr);
      }

      @media (width >= 1024px) {
        grid-template-columns: repeat(6, 1fr);
      }

      display: grid;
      gap: 1rem;
      margin: 0 auto;
      max-width: var(--max-width);
    }
  }
</style>
