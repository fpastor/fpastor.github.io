---
import MainProject from "./MainProject.astro";
import SideProject from "./SideProject.astro";

const projects = {
  mainProject: {
    title: "NEURAL_NET DASHBOARD",
    description:
      "Real-time threat detection interface built with React, Three.js, and high-performance WebGL shaders.",
    imageUrl:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuBwVu9wycIn7nrtyLs0JD4gyMQzyCLSWsTaFXDlV8csIGmwWR1wNEBBXBvKZRIEoIKplYbVTlCY1IRGdtFCmwdc8Su1jISkjVuBrxeP9uRTnUVY7p-cfymnihTCQTfWbEFMFZnDo8_X3LjWoxcXrGAQhBKdtz031Tmb8L9IKvb5U2eF-3BmCeJYA0z-wn3BBZUWPHjacVoSuOOur-0IQY6I8e5RJ4E1eM9DR9aGjOJSZCu4z2vSpATBzRh67Gx9q1WDDcK0sEkx-y8",
    imageAlt: "Neural Net Dashboard",
    tags: ["Web3", "Security"],
  },
  sideProjects: [
    {
      title: "OS_KNOT COMPONENT LIB",
      imageUrl:
        "https://lh3.googleusercontent.com/aida-public/AB6AXuDuUGRwJ6oFNgDv59QsDPLGstcSht_3ArmwEAjVRK1lEegIhm1u3pFORVQHqPfNyNT0gHIBl6wMQ6yaxFi15fdz_8hjJnEPX4RwamDuC9lqKICWG2Qv9kUIlczRApTVxib4W34yHX0RbdIKKoo_pWVrp-gWNKAFYDwqqYUivHGu1rQywSgz4YwfDXrUDznQELRA7NLSUkhnpGM-jixGrj7vlZ8v-YgsqZ2njbm4-Z8DB0JmzC2xkJmkuzIMAHB14vOyOwoX11IUVK0",
      imageAlt: "Code Snippets",
      meta: "NPM Package // 45k Weekly Downloads",
    },
    {
      title: "SYNTH_CORE INFRA",
      imageUrl:
        "https://lh3.googleusercontent.com/aida-public/AB6AXuBLur2r7UZI_6fgTt1o3_LwjCunSupIJKaQxojoI2WsAkaKlgGHudoD098oD4e7V7fkeXW34fuFLJI8kwmsgXyqBv51f_x8vJ_MyRhad-aqzGW7FckoXozZCozIvBv_Kj53qUP5xmwwZ_T7LkImyvJ-QIxMDskll0TBUyvGRzOxG5nlpMflJCfJ3hevr2lT_PxsQh3Lm_v0u6Cd-21v_RjVFW_yjtmLi3oMub812gj27XS7TSF2DqXekn7dFaiN_T_fn4jkwwdNF50",
      imageAlt: "Data Center",
      meta: "Infrastructure as Code // Terraform",
    },
  ],
};
---

<section class="container projects-section">
  <div class="section-header">
    <div>
      <span class="tag">SELECTED_ARCHIVES</span>
      <h2>Core Projects</h2>
    </div>
    <div class="header-meta">
      Sorted by Intensity<br />Updated: 2024.05
    </div>
  </div>
  <div class="projects-layout">
    <MainProject
      title={projects.mainProject.title}
      description={projects.mainProject.description}
      imageUrl={projects.mainProject.imageUrl}
      imageAlt={projects.mainProject.imageAlt}
      tags={projects.mainProject.tags}
    />
    <div class="side-projects">
      {
        projects.sideProjects.map((project) => (
          <SideProject
            title={project.title}
            imageUrl={project.imageUrl}
            imageAlt={project.imageAlt}
            meta={project.meta}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding: 8rem 0;

    & .section-header {
      align-items: flex-end;
      border-bottom: 1px solid rgb(171 173 174 / 15%);
      display: flex;
      justify-content: space-between;
      margin-bottom: 5rem;
      padding-bottom: 2rem;

      & .tag {
        color: var(--primary);
        font-family: var(--font-headline);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }

      & h2 {
        font-family: var(--font-headline);
        font-size: 3rem;
        font-weight: 700;
        letter-spacing: -0.05em;
        text-transform: uppercase;
      }

      & .header-meta {
        @media (width < 768px) {
          display: none;
        }

        @media (width >= 768px) {
          display: block;
        }

        color: var(--outline);
        font-family: var(--font-headline);
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        text-align: right;
        text-transform: uppercase;
      }
    }
  }

  .projects-layout {
    @media (width >= 1024px) {
      grid-template-columns: repeat(12, 1fr);
    }

    @media (width < 1024px) {
      grid-template-columns: 1fr;
    }

    display: grid;
    gap: 3rem;
  }

  .side-projects {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    grid-column: span 12;
  }

  @media (width >= 1024px) {
    .side-projects {
      grid-column: span 4;
    }
  }
</style>
