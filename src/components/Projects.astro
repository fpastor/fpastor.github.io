---
import GitHub from "./icons/GitHub.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";
import Microsoft from "./icons/Microsoft.astro";
import CSharp from "./icons/CSharp.astro";

const TAGS = {
  WPF: {
    name: "WPF",
    class: "bg-white text-black",
    icon: CSharp,
  },
  DOTNET: {
    name: ".NET",
    class: "bg-white text-black",
    icon: Microsoft,
  },
};

const PROJECTS = [
  {
    title: "GameCollector",
    description:
      "GameCollector es un proyecto personal para llevar un registro de los juegos que tengo en mi colección. Está desarrollado con Next.js y Tailwind CSS.",
    link: "https://youtu.be/J4CKDoP9cSY",
    github: "",
    image: "/projects/gamecollector.png",
    tags: [TAGS.DOTNET, TAGS.WPF],
  },
];
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ image, title, description, tags, link, github }) => (
      <article>
        <div>
          <div>
            <img alt="GameCollector screenshot" loading="lazy" src={image} />
          </div>
        </div>

        <div>
          <h3>{title}</h3>
          <div>
            <ul>
              {tags.map((tag) => (
                <li>
                  <span>
                    <tag.icon class="size-4" />
                    {tag.name}
                  </span>
                </li>
              ))}
            </ul>

            <div>{description}</div>
            <footer>
              {github && (
                <LinkButton href={github}>
                  <GitHub />
                  Code
                </LinkButton>
              )}
              {link && (
                <LinkButton href={link}>
                  <Link />
                  Preview
                </LinkButton>
              )}
            </footer>
          </div>
        </div>
      </article>
    ))
  }
</div>
