---
import Icon from "./Icon.astro";
import LinkButton from "./LinkButton.astro";

const TAGS = {
  WPF: {
    name: "WPF",
    class: "bg-white text-black",
    iconName: "csharp",
  },
  DOTNET: {
    name: ".NET",
    class: "bg-white text-black",
    iconName: "microsoft",
  },
};

const PROJECTS = [
  {
    title: "GameCollector",
    description:
      "GameCollector es un proyecto personal para llevar un registro de los juegos que tengo en mi colección. Está desarrollado con Next.js y Tailwind CSS.",
    link: "https://youtu.be/J4CKDoP9cSY",
    github: "",
    image: "/projects/gamecollector.png",
    tags: [TAGS.DOTNET, TAGS.WPF],
  },
];
---

<div class="projects">
  {
    PROJECTS.map(({ image, title, description, tags, link, github }) => (
      <article class="project-item">
        <figure class="project-media">
          <img alt="GameCollector screenshot" loading="lazy" src={image} />
        </figure>

        <div class="project-body">
          <h3>{title}</h3>
          <ul class="project-tags">
            {tags.map((tag) => (
              <li class="tag">
                <span>
                  <Icon name={tag.iconName} size="var(--icon-sm)" />
                  {tag.name}
                </span>
              </li>
            ))}
          </ul>

          <p class="project-desc">{description}</p>
          <footer class="project-meta">
            {github && (
              <LinkButton href={github}>
                <Icon name="github" size="var(--icon-sm)" />
                Code
              </LinkButton>
            )}
            {link && (
              <LinkButton href={link}>
                <Icon name="link" size="var(--icon-sm)" />
                Preview
              </LinkButton>
            )}
          </footer>
        </div>
      </article>
    ))
  }
</div>

<style>
  .projects {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .project-item {
    align-items: start;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr 1fr;
  }

  .project-media img {
    border-radius: 10px;
    box-shadow: 0 8px 20px rgb(2 6 23 / 6%);
    width: 100%;
  }

  .project-body h3 {
    margin: 0 0 0.5rem;
  }

  .project-tags {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    margin: 0 0 0.75rem;
    padding: 0;
  }

  .tag span {
    align-items: center;
    background: rgb(2 6 23 / 4%);
    border-radius: 9999px;
    display: inline-flex;
    gap: 0.5rem;
    padding: 0.3rem 0.5rem;
  }

  .project-desc {
    margin: 0 0 1rem;
  }

  .project-meta {
    display: flex;
    gap: 0.5rem;
  }

  @media (width <= 900px) {
    .project-item {
      grid-template-columns: 1fr;
    }
  }
</style>
