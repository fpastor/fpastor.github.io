---
import Icon from "./Icon.astro";
---

<button id="theme-toggle-btn" aria-pressed="false" aria-label="Alternar tema">
  <span class="sr-only">Alternar tema claro/oscuro</span>
  <Icon
    id="icon-light"
    class="theme-toggle-icon"
    name="sun"
    size="var(--icon-size-md)"
    stroke="currentColor"
  />
  <Icon
    id="icon-dark"
    class="theme-toggle-icon"
    name="moon"
    size="var(--icon-size-md)"
    stroke="currentColor"
  />
</button>

<style lang="scss">
  #theme-toggle-btn {
    align-items: center;
    background: transparent;
    border: 1px solid orange;
    border-radius: var(--radius-full);
    cursor: pointer;
    display: flex;
    flex-direction: row;
    padding: 0.1rem;
  }

  .theme-toggle-icon {
    border-radius: var(--radius-full);
    height: 1.25rem;
    padding: 0.25rem;
    transition:
      opacity 0.12s ease,
      transform 0.12s ease;
    width: 1.25rem;
  }

  #icon-light.hidden {
    background-color: transparent;
    color: white;
    opacity: 0.5;
  }

  #icon-light.visible {
    background-color: orange;
    color: white;
  }

  #icon-dark.hidden {
    background-color: transparent;
    opacity: 0.5;
  }

  #icon-dark.visible {
    background-color: lime;
    color: rgb(0 0 0 / 66%);
  }

  /* explícito: usuario forzó dark */
  [data-theme="dark"] #theme-toggle-btn {
    border-color: lime;
  }

  #theme-toggle-btn {
    border-color: var(--toggle-border-color);
  }
</style>

<script is:inline>
  const btn = document.getElementById("theme-toggle-btn");
  const light = document.getElementById("icon-light");
  const dark = document.getElementById("icon-dark");
  const mq = window.matchMedia("(prefers-color-scheme: dark)");

  const getStored = () => localStorage.getItem("theme");
  const store = (t) => {
    if (t === null || t === "system") {
      localStorage.removeItem("theme");
    } else {
      localStorage.setItem("theme", t);
    }
  };

  // resolve returns: 'light'|'dark'|'system'
  const resolve = () => {
    const stored = getStored();
    if (stored === "light" || stored === "dark") return stored;
    return "system";
  };

  const apply = (theme) => {
    if (theme === "system") {
      // remove explicit attribute, let media query decide
      document.documentElement.removeAttribute("data-theme");
      const isDarkNow = mq.matches;
      light.classList.toggle("visible", !isDarkNow);
      light.classList.toggle("hidden", isDarkNow);
      dark.classList.toggle("visible", isDarkNow);
      dark.classList.toggle("hidden", !isDarkNow);
      btn.setAttribute("aria-pressed", isDarkNow ? "true" : "false");
      window.dispatchEvent(
        new CustomEvent("theme:change", { detail: "system" })
      );
      return;
    }

    if (theme === "dark") {
      document.documentElement.setAttribute("data-theme", "dark");
    } else {
      document.documentElement.setAttribute("data-theme", "light");
    }

    const isDark = theme === "dark";
    light.classList.toggle("visible", !isDark);
    light.classList.toggle("hidden", isDark);
    dark.classList.toggle("visible", isDark);
    dark.classList.toggle("hidden", !isDark);
    btn.setAttribute("aria-pressed", isDark ? "true" : "false");
    window.dispatchEvent(new CustomEvent("theme:change", { detail: theme }));
  };

  // initial
  apply(resolve());

  mq.addEventListener("change", () => {
    const stored = getStored();
    if (!stored) apply(resolve());
  });

  // click toggles between explicit light <-> dark only
  btn.addEventListener("click", () => {
    const stored = getStored();
    const isDarkNow = mq.matches;
    let next;

    if (!stored) {
      // first interaction: flip the current effective theme
      next = isDarkNow ? "light" : "dark";
    } else {
      next = stored === "dark" ? "light" : "dark";
    }

    store(next);
    apply(next);
  });
</script>
