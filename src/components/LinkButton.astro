---
const { href } = Astro.props;
---

<a target="_blank" href={href} role="link" class="link-button">
  <slot />
</a>

<style>
  .link-button {
    align-items: center;
    background: var(--accent);
    border-radius: 8px;
    color: white;
    display: inline-flex;
    font-weight: 600;
    gap: 0.5rem;
    padding: 0.45rem 0.75rem;
    text-decoration: none;
  }

  .link-button:hover {
    transform: translateY(-1px);
  }
</style>
