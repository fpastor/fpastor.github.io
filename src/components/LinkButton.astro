---
const { href } = Astro.props;
---

<a target="_blank" href={href} role="link" class="link-button">
  <slot />
</a>

<style>
  .link-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.75rem;
    border-radius: 8px;
    background: var(--accent);
    color: white;
    text-decoration: none;
    font-weight: 600;
  }
  .link-button:hover {
    transform: translateY(-1px);
  }
</style>
