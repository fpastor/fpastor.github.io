---
interface Props {
  url?: string;
  target?: string;
  rel?: string;
}

const { url, target = "_blank", rel = "noopener" } = Astro.props;
---

{
  url ? (
    <a href={url} target={target} rel={rel} class="badge">
      <slot />
    </a>
  ) : (
    <span class="badge">
      <slot />
    </span>
  )
}

<style>
  .badge {
    background: var(--bg-badge);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    display: inline-block;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    padding: var(--space-xxs) var(--space-sm);
  }
</style>
