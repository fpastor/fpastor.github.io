---
interface RelatedCardProps {
  title: string;
  category: string;
  imgSrc: string;
  imgAlt: string;
}

const { title, category, imgAlt, imgSrc } = Astro.props as RelatedCardProps;
---

<div class="card">
  <div class="card-image-wrapper">
    <img alt={imgAlt} class="card-image" src={imgSrc} />
  </div>
  <span class="card-category" style="color: var(--secondary);">{category}</span>
  <h4 class="card-title">{title}</h4>
</div>

<style>
  .card {
    cursor: pointer;
  }

  .card-image-wrapper {
    aspect-ratio: 16 / 9;
    background: var(--surface-container-low);
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .card-image {
    filter: grayscale(100%);
    height: 100%;
    object-fit: cover;
    transition: all 0.5s;
    width: 100%;
  }

  .card:hover .card-image {
    filter: grayscale(0%);
    transform: scale(1.05);
  }

  .card-category {
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .card-title {
    font-family: var(--font-headline);
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 0.5rem;
    transition: color 0.2s;
  }

  .card:hover .card-title {
    color: var(--primary);
  }
</style>
