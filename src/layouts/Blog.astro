---
import "@fontsource-variable/onest";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "@/styles/global.scss";

interface Props {
  frontmatter?: {
    title?: string;
    date?: string;
    slug?: string;
    author?: string;
    categories?: string[];
    tags?: string[];
    headerImage?: string;
  };
}

const { frontmatter } = Astro.props as Props;

const title = frontmatter?.title ?? "Default Title";

const date = frontmatter?.date
  ? new Date(frontmatter.date).toLocaleDateString("es-ES", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "Unknown Date";

const slug = frontmatter?.slug ?? "unknown-slug";
const author = frontmatter?.author ?? "Unknown Author";
const categories = frontmatter?.categories ?? [];
const tags = frontmatter?.tags ?? [];
const headerImage = frontmatter?.headerImage ?? "";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Onest:wght@100..900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <script is:inline>
      // Apply explicit user theme as data attribute early to avoid FOUC.
      (function () {
        try {
          var t = localStorage.getItem("theme");
          if (t === "light" || t === "dark") {
            document.documentElement.setAttribute("data-theme", t);
          }
        } catch (e) {
          /* ignore */
        }
      })();
    </script>
  </head>
  <body>
    <div class="pattern-bg" aria-hidden="true"></div>
    <div class="container">
      <div class="header">
        <div class="background" style={`--bg-image: url(${headerImage})`}>
          <div class="overlay">
            <h1>{frontmatter?.title}</h1>
            <p class="credit">
              Escrito el <span class="date">{date}</span> por <span
                class="author">{author}</span
              > en
              {
                categories.length > 0 && (
                  <>
                    {categories.map((category, index) => (
                      <span class="category">
                        {category}
                        {index < categories.length - 1 ? ", " : ""}
                      </span>
                    ))}
                  </>
                )
              }
            </p>
          </div>
        </div>
      </div>

      <div class="content">
        <slot />

        <div class="tag-list">
          {
            tags.length > 0 && (
              <>
                {tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </>
            )
          }
        </div>
      </div>

      <Footer />
    </div>
  </body>

  <style is:global>
    :root {
      /* keep */
    }

    html {
      font-family: "Onest Variable", sans-serif;
      scroll-behavior: smooth;
    }

    body {
      align-items: center;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    .header {
      display: flex;
      min-height: 240px;
      overflow: hidden;
      position: relative;

      .background {
        display: flex;
        inset: 0;
        width: 100%;
      }

      .background::before {
        background-image: var(--bg-image);
        background-position: center center;
        background-size: cover;
        content: "";
        filter: blur(2px);
        inset: 0;
        pointer-events: none;
        position: absolute;
        transform: scale(1.1);
        z-index: 0;
      }

      .overlay {
        background-color: rgb(255 255 0 / 50%);
        color: white;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        height: 100%;
        justify-content: center;
        padding: 1rem;
        position: relative;
        text-align: center;
        width: 100%;
        z-index: 1;
      }

      h1 {
        font-size: 3rem;
        margin: 0;
        padding: 0;
      }

      .credit {
        color: var(--color-muted);
        font-size: 0.875rem;
      }

      .date,
      .author,
      .category {
        color: var(--color-accent);
        text-transform: lowercase;
      }
    }

    .content {
      display: flex;
      flex-direction: column;
      margin: 0 auto;
      max-width: 1100px;
      padding: 1rem;

      p + p {
        padding-top: 1rem;
      }

      img {
        align-self: center;
        border-radius: 12px;
        max-height: 480px;
        padding: 1rem;
      }
    }

    .tag-list {
      align-items: center;
      display: flex;
      flex-flow: row wrap;
      gap: 0.25rem;
      justify-content: center;
      padding: 1rem;

      .tag {
        background-color: var(--color-primary);
        border-radius: 4px;
        font-size: 0.75rem;
        padding: 0 0.25rem;
      }
    }

    p {
      margin: 0;
      padding: 0;
    }

    .broken-link {
      color: var(--color-muted);
      text-decoration: line-through !important;

      a {
        color: inherit;
        pointer-events: none;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      html {
        scroll-behavior: auto;
      }
    }
  </style>
</html>
