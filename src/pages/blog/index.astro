---
import Layout from "@/layouts/Layout.astro";
const posts = Object.values(
  import.meta.glob("@/pages/blog/*.md", { eager: true })
);
---

<Layout
  title="Blog de Fernando Pastor - Diseño, Desarrollo y Progración de Aplicaciones Multiplataforma"
  description="Lalala"
>
  <main>
    <h1>Blog</h1>

    <ul>
      {
        posts.map((post) => (
          <li>
            <a href={post.url}>{post.frontmatter.title}</a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
